<?xml version="1.0"?>
<robot name="reservoir">

  <!-- Base link (bottom plate of reservoir) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 0.02"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Front wall -->
  <link name="wall_front">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.02 0.3"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.02 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Back wall -->
  <link name="wall_back">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.02 0.3"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.02 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Left wall -->
  <link name="wall_left">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.56 0.3"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.56 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Gate link (rotating lid - thicker and bright colored) -->
  <link name="gate">
    <visual>
      <origin xyz="0 -0.28 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.56 0.56 0.04"/>
      </geometry>
      <material name="bright_blue">
        <color rgba="0.2 0.6 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.28 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.56 0.56 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.28 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <!-- Fixed joints for walls -->
  <joint name="wall_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wall_front"/>
    <origin xyz="0 -0.29 0" rpy="0 0 0"/>
  </joint>

  <joint name="wall_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wall_back"/>
    <origin xyz="0 0.29 0" rpy="0 0 0"/>
  </joint>

  <joint name="wall_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wall_left"/>
    <origin xyz="-0.29 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Revolute joint for gate (rotates around X-axis at the back edge) -->
  <joint name="gate_joint" type="revolute">
    <parent link="base_link"/>
    <child link="gate"/>
    <origin xyz="0 0.28 0.3" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.57" effort="10" velocity="2.0"/>
  </joint>

</robot>
