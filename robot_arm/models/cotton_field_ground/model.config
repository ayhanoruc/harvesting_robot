<?xml version="1.0"?>
<model>
  <name>cotton_field_ground</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>
  <author>
    <name>Extracted from cotton_orchard_static_no_trees.dae via
          extract_field_ground.py — Ground node only, all plant
          (branch/pedicel/socket) nodes stripped.</name>
  </author>
  <description>
    Textured field terrain visual for cotton_demo. Provides the dirt+grass
    ground texture from Deniz's bundle without re-importing the 12 baked
    clusters. Pair with template-instanced clusters at custom positions.
  </description>
</model>
