<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="arm">
	<!-- Xacro arguments (injected from launch file) -->
	<xacro:arg name="controllers_yaml" default=""/>

	<!-- World link (fixed reference) -->
	<link name="world"/>

	<!-- Base Link -->
	<link name="base_link">
		<inertial>
			<mass value="1.0"/>
			<origin rpy="0 0 0" xyz="0 0 0.025"/>
			<inertia ixx="0.0027" iyy="0.0027" izz="0.005" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<cylinder length="0.05" radius="0.1"/>
			</geometry>
			<material name="silver">
				<color rgba="0.75 0.75 0.75 1"/>
			</material>
			<origin rpy="0 0 0" xyz="0 0 0.025"/>
		</visual>
		<collision>
			<geometry>
				<cylinder length="0.05" radius="0.1"/>
			</geometry>
			<origin rpy="0 0 0" xyz="0 0 0.025"/>
		</collision>
	</link>

	<joint name="fixed" type="fixed">
		<parent link="world"/>
		<child link="base_link"/>
	</joint>

	<!-- Torso (rotates around Z axis) -->
	<link name="torso">
		<inertial>
			<mass value="1.0"/>
			<origin rpy="0 0 0" xyz="0 0 0.25"/>
			<inertia ixx="0.02146" iyy="0.02146" izz="0.00125" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<cylinder length="0.5" radius="0.05"/>
			</geometry>
			<material name="silver">
				<color rgba="0.75 0.75 0.75 1"/>
			</material>
			<origin rpy="0 0 0" xyz="0.0 0.0 0.25"/>
		</visual>
		<collision>
			<geometry>
				<cylinder length="0.5" radius="0.05"/>
			</geometry>
			<origin rpy="0 0 0" xyz="0.0 0.0 0.25"/>
		</collision>
	</link>

	<joint name="hip" type="continuous">
		<axis xyz="0 0 1"/>
		<parent link="base_link"/>
		<child link="torso"/>
		<origin rpy="0 0 0" xyz="0 0 0.05"/>
	</joint>

	<!-- Upper Arm -->
	<link name="upper_arm">
		<inertial>
			<mass value="1.0"/>
			<origin rpy="0 0 0" xyz="0 0 0.2"/>
			<inertia ixx="0.01396" iyy="0.01396" izz="0.00125" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<cylinder length="0.4" radius="0.05"/>
			</geometry>
			<material name="silver"/>
			<origin rpy="0 0 0" xyz="0 0 0.2"/>
		</visual>
		<collision>
			<geometry>
				<cylinder length="0.4" radius="0.05"/>
			</geometry>
			<origin rpy="0 0 0" xyz="0 0 0.2"/>
		</collision>
	</link>

	<joint name="shoulder" type="revolute">
		<axis xyz="0 1 0"/>
		<limit velocity="1.0" effort="30.0" upper="0.6981" lower="-1.5708"/>
		<parent link="torso"/>
		<child link="upper_arm"/>
		<origin rpy="0 1.5708 0" xyz="0.0 -0.1 0.45"/>
	</joint>

	<!-- Lower Arm -->
	<link name="lower_arm">
		<inertial>
			<mass value="1.0"/>
			<origin rpy="0 0 0" xyz="0 0 0.2"/>
			<inertia ixx="0.01396" iyy="0.01396" izz="0.00125" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<cylinder length="0.4" radius="0.05"/>
			</geometry>
			<material name="silver"/>
			<origin rpy="0 0 0" xyz="0 0 0.2"/>
		</visual>
		<collision>
			<geometry>
				<cylinder length="0.4" radius="0.05"/>
			</geometry>
			<origin rpy="0 0 0" xyz="0 0 0.2"/>
		</collision>
	</link>

	<joint name="elbow" type="revolute">
		<axis xyz="0 1 0"/>
		<limit velocity="1.0" effort="30.0" upper="1.5708" lower="-1.5708"/>
		<parent link="upper_arm"/>
		<child link="lower_arm"/>
		<origin rpy="0 0 0" xyz="0.0 0.1 0.35"/>
	</joint>

	<!-- Hand -->
	<link name="hand">
		<inertial>
			<mass value="1.0"/>
			<inertia ixx="0.00042" iyy="0.00042" izz="0.00042" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<box size="0.05 0.05 0.05"/>
			</geometry>
			<material name="silver"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.05 0.05 0.05"/>
			</geometry>
		</collision>
	</link>

	<joint name="wrist" type="continuous">
		<axis xyz="0 1 0"/>
		<parent link="lower_arm"/>
		<child link="hand"/>
		<origin rpy="0 0 0" xyz="0.0 0.0 0.425"/>
	</joint>

	<!-- Left Gripper Base -->
	<link name="left_gripper_base">
		<inertial>
			<mass value="0.01"/>
			<!-- Box approx: 0.005 x 0.005 x 0.02 (see visual). Keep inertia physically consistent. -->
			<inertia ixx="3.54e-7" iyy="3.54e-7" izz="4.17e-8" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<box size="0.005 0.005 0.02"/>
			</geometry>
			<material name="silver"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.005 0.005 0.02"/>
			</geometry>
		</collision>
	</link>

	<joint name="l_g_base" type="revolute">
		<axis xyz="1 0 0"/>
		<limit velocity="1.0" effort="30.0" lower="0" upper="0.5236"/>
		<origin rpy="-0.9162 0 0" xyz="0 0.02 0.035"/>
		<parent link="hand"/>
		<child link="left_gripper_base"/>
	</joint>

	<!-- Right Gripper Base -->
	<link name="right_gripper_base">
		<inertial>
			<mass value="0.01"/>
			<!-- Box approx: 0.005 x 0.005 x 0.02 (see visual). Keep inertia physically consistent. -->
			<inertia ixx="3.54e-7" iyy="3.54e-7" izz="4.17e-8" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<box size="0.005 0.005 0.02"/>
			</geometry>
			<material name="silver"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.005 0.005 0.02"/>
			</geometry>
		</collision>
	</link>

	<joint name="r_g_base" type="revolute">
		<axis xyz="1 0 0"/>
		<limit velocity="1.0" effort="100.0" upper="0" lower="-0.5236"/>
		<origin rpy="0.9162 0 0" xyz="0 -0.02 0.035"/>
		<parent link="hand"/>
		<child link="right_gripper_base"/>
	</joint>

	<!-- Left Gripper Finger -->
	<link name="left_gripper_finger">
		<inertial>
			<mass value="0.01"/>
			<inertia ixx="1.57e-7" iyy="1.57e-7" izz="6.8e-7" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<box size="0.008 0.008 0.05"/>
			</geometry>
			<material name="silver"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.008 0.008 0.05"/>
			</geometry>
		</collision>
	</link>

	<joint name="l_g_finger" type="fixed">
		<origin rpy="0.3926 0 0" xyz="0 -0.01 0.03"/>
		<parent link="left_gripper_base"/>
		<child link="left_gripper_finger"/>
	</joint>

	<!-- Right Gripper Finger -->
	<link name="right_gripper_finger">
		<inertial>
			<mass value="0.01"/>
			<inertia ixx="1.57e-7" iyy="1.57e-7" izz="6.8e-7" ixy="0" ixz="0" iyz="0"/>
		</inertial>
		<visual>
			<geometry>
				<box size="0.008 0.008 0.05"/>
			</geometry>
			<material name="silver"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.005 0.005 0.05"/>
			</geometry>
		</collision>
	</link>

	<joint name="r_g_finger" type="fixed">
		<origin rpy="-0.3926 0 0" xyz="0 0.01 0.03"/>
		<parent link="right_gripper_base"/>
		<child link="right_gripper_finger"/>
	</joint>

	<!-- TCP frames -->
	<joint name="tool0_joint" type="fixed">
		<origin xyz="0 0 0.025" rpy="0 0 0"/>
		<parent link="hand"/>
		<child link="tool0"/>
	</joint>
	<link name="tool0"/>

	<joint name="tcp_joint" type="fixed">
		<origin xyz="0 0 0.045" rpy="0 0 0"/>
		<parent link="tool0"/>
		<child link="tcp"/>
	</joint>
	<link name="tcp">
		<visual>
			<geometry>
				<sphere radius="0.01"/>
			</geometry>
			<material name="tcp_red">
				<color rgba="1 0 0 1"/>
			</material>
		</visual>
	</link>

	<gazebo reference="tcp">
		<material>Gazebo/Red</material>
	</gazebo>

	<!-- ==================== Wrist-Mounted Camera ==================== -->
	<!-- Camera link attached to tool0, offset to avoid gripper clipping -->
	<joint name="camera_joint" type="fixed">
		<parent link="tool0"/>
		<child link="camera_link"/>
		<origin xyz="0.02 0 0.01" rpy="0 0.3 0"/>  <!-- Slightly forward and tilted down -->
	</joint>
	<link name="camera_link">
		<visual>
			<geometry>
				<box size="0.02 0.03 0.02"/>
			</geometry>
			<material name="camera_black">
				<color rgba="0.1 0.1 0.1 1"/>
			</material>
		</visual>
		<collision>
			<geometry>
				<box size="0.02 0.03 0.02"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.05"/>
			<inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
		</inertial>
	</link>

	<!-- ROS optical frame convention: Z forward, X right, Y down -->
	<joint name="camera_optical_joint" type="fixed">
		<parent link="camera_link"/>
		<child link="camera_optical_frame"/>
		<origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
	</joint>
	<link name="camera_optical_frame"/>

	<!-- Gazebo camera (material + RGB-D sensor) -->
	<gazebo reference="camera_link">
		<material>Gazebo/Black</material>
		<sensor type="depth" name="wrist_rgbd_camera">
			<always_on>true</always_on>
			<update_rate>30.0</update_rate>
			<camera name="wrist_camera">
				<horizontal_fov>1.047</horizontal_fov>
				<image>
					<width>640</width>
					<height>480</height>
					<format>R8G8B8</format>
				</image>
				<clip>
					<near>0.05</near>
					<far>3.0</far>
				</clip>
				<noise>
					<type>gaussian</type>
					<mean>0.0</mean>
					<stddev>0.007</stddev>
				</noise>
			</camera>
			<plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
				<ros>
					<namespace>/camera</namespace>
					<remapping>image_raw:=color/image_raw</remapping>
					<remapping>camera_info:=color/camera_info</remapping>
					<remapping>depth/image_raw:=depth/image_raw</remapping>
					<remapping>depth/camera_info:=depth/camera_info</remapping>
					<remapping>points:=depth/points</remapping>
				</ros>
				<camera_name>wrist</camera_name>
				<frame_name>camera_optical_frame</frame_name>
				<hack_baseline>0.07</hack_baseline>
				<min_depth>0.05</min_depth>
				<max_depth>3.0</max_depth>
			</plugin>
		</sensor>
	</gazebo>

	<!-- ==================== ros2_control ==================== -->
	<ros2_control name="robot_arm_control" type="system">
		<hardware>
			<plugin>gazebo_ros2_control/GazeboSystem</plugin>
		</hardware>
		<joint name="hip">
			<command_interface name="position">
				<param name="min">-3.14159</param>
				<param name="max">3.14159</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="shoulder">
			<command_interface name="position">
				<param name="min">-1.5708</param>
				<param name="max">0.6981</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="elbow">
			<command_interface name="position">
				<param name="min">-1.5708</param>
				<param name="max">1.5708</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="wrist">
			<command_interface name="position">
				<param name="min">-3.14159</param>
				<param name="max">3.14159</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="l_g_base">
			<command_interface name="position">
				<param name="min">0</param>
				<param name="max">0.5236</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="r_g_base">
			<command_interface name="position">
				<param name="min">-0.5236</param>
				<param name="max">0</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
	</ros2_control>

	<!-- ==================== Gazebo ROS2 Control Plugin ==================== -->
	<gazebo>
		<plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
			<parameters>$(arg controllers_yaml)</parameters>
		</plugin>
	</gazebo>

	<!-- Gazebo material colors -->
	<gazebo reference="base_link">
		<material>Gazebo/Grey</material>
	</gazebo>
	<gazebo reference="torso">
		<material>Gazebo/Grey</material>
	</gazebo>
	<gazebo reference="upper_arm">
		<material>Gazebo/Grey</material>
	</gazebo>
	<gazebo reference="lower_arm">
		<material>Gazebo/Grey</material>
	</gazebo>
	<gazebo reference="hand">
		<material>Gazebo/Grey</material>
	</gazebo>
	<gazebo reference="left_gripper_base">
		<material>Gazebo/Grey</material>
	</gazebo>
	<gazebo reference="right_gripper_base">
		<material>Gazebo/Grey</material>
	</gazebo>
	<gazebo reference="left_gripper_finger">
		<material>Gazebo/Grey</material>
	</gazebo>
	<gazebo reference="right_gripper_finger">
		<material>Gazebo/Grey</material>
	</gazebo>

</robot>
