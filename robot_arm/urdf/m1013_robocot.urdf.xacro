<?xml version="1.0"?>
<!--
  RoboCot M1013 + Robotiq Hand-E + Wrist RGB-D Camera
  Gazebo Ignition Fortress compatible (ros2_control + gz_ros2_control)

  Ported from:
    - robocob_ws_sim/doosan-robot/dsr_description (M1013 arm)
    - robocob_ws_sim/robotiq/robotiq_description (Hand-E gripper)
    - harvesting_ws mybot.urdf.xacro (camera + ros2_control pattern)
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="m1013_robocot">
	<xacro:arg name="controllers_yaml" default=""/>
	<!-- standalone=true: arm sits on its own at world (orchard_test, sim demo)
	     standalone=false: arm is attached to a parent (Husky deck) by the
	     including URDF, which defines its own world/base joint. -->
	<xacro:arg name="standalone" default="true"/>

	<!-- ==================== Standalone-only world fixture ==================== -->
	<xacro:if value="$(arg standalone)">
		<link name="world"/>
		<joint name="world_fixed" type="fixed">
			<origin xyz="0 0 0.1" rpy="0 0 0"/>
			<parent link="world"/>
			<child link="base_0"/>
		</joint>
	</xacro:if>

	<!-- ==================== M1013 Arm ==================== -->
	<!-- Base (link0) -->
	<link name="base_0">
		<inertial>
			<mass value="4.12"/>
			<origin xyz="-3.4e-05 -0.004815 0.048482"/>
			<inertia ixx="0.016331" ixy="-6.4837e-06" ixz="2.0048e-06" iyy="0.014945" iyz="-0.00051686" izz="0.022577"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_0_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_0_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
	</link>

	<!-- Joint 1 (base rotation) -->
	<joint name="joint1" type="revolute">
		<parent link="base_0"/>
		<child link="link1"/>
		<origin rpy="0 0 0" xyz="0 0 0.1525"/>
		<axis xyz="0 0 1"/>
		<limit effort="346" lower="-6.2832" upper="6.2832" velocity="2.0944"/>
		<dynamics friction="0"/>
	</joint>
	<link name="link1">
		<inertial>
			<mass value="7.8"/>
			<origin xyz="0.000119 0.0428 -0.006383"/>
			<inertia ixx="0.04506" ixy="4.1126e-05" ixz="-5.2533e-05" iyy="0.029679" iyz="-0.0019959" izz="0.047056"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_1_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_1_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
	</link>

	<!-- Joint 2 (shoulder) -->
	<joint name="joint2" type="revolute">
		<parent link="link1"/>
		<child link="link2"/>
		<origin rpy="0 -1.571 -1.571" xyz="0 0.0345 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="346" lower="-6.2832" upper="6.2832" velocity="2.0944"/>
		<dynamics friction="0"/>
	</joint>
	<link name="link2">
		<inertial>
			<mass value="10.83"/>
			<origin xyz="0.25973 -5.3e-05 0.15782"/>
			<inertia ixx="0.037586" ixy="-0.00036999" ixz="-0.0069927" iyy="0.84943" iyz="4.0201e-05" izz="0.85021"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_2_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_2_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_2_1.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_2_1.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_2_2.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_2_2.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
	</link>

	<!-- Joint 3 (elbow) -->
	<joint name="joint3" type="revolute">
		<parent link="link2"/>
		<child link="link3"/>
		<origin rpy="0 0 1.571" xyz="0.62 0 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="163" lower="-2.7925" upper="2.7925" velocity="3.1416"/>
		<dynamics friction="0"/>
	</joint>
	<link name="link3">
		<inertial>
			<mass value="3.68"/>
			<origin xyz="-1.5e-05 -0.006702 0.044608"/>
			<inertia ixx="0.018748" ixy="7.8071e-06" ixz="-5.0324e-06" iyy="0.018972" iyz="-0.00099342" izz="0.011502"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_3_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_3_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
	</link>

	<!-- Joint 4 (wrist 1) -->
	<joint name="joint4" type="revolute">
		<parent link="link3"/>
		<child link="link4"/>
		<origin rpy="1.571 0 0" xyz="0 -0.559 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="50" lower="-6.2832" upper="6.2832" velocity="3.927"/>
		<dynamics friction="0"/>
	</joint>
	<link name="link4">
		<inertial>
			<mass value="3.82"/>
			<origin xyz="7.1e-05 0.091879 -0.18252"/>
			<inertia ixx="0.19063" ixy="-1.8037e-05" ixz="-3.8576e-05" iyy="0.17268" iyz="-0.052996" izz="0.030386"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_4_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_4_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_4_1.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_4_1.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
	</link>

	<!-- Joint 5 (wrist 2) -->
	<joint name="joint5" type="revolute">
		<parent link="link4"/>
		<child link="link5"/>
		<origin rpy="-1.571 0 0" xyz="0 0 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="50" lower="-6.2832" upper="6.2832" velocity="3.927"/>
		<dynamics friction="0"/>
	</joint>
	<link name="link5">
		<inertial>
			<mass value="2.82"/>
			<origin xyz="-0.000273 0.003651 0.032088"/>
			<inertia ixx="0.015583" ixy="2.135e-05" ixz="-5.1895e-06" iyy="0.011519" iyz="0.00042553" izz="0.0088671"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_5_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_5_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
	</link>

	<!-- Joint 6 (wrist 3 / tool flange) -->
	<joint name="joint6" type="revolute">
		<parent link="link5"/>
		<child link="link6"/>
		<origin rpy="1.571 0 0" xyz="0 -0.121 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="50" lower="-6.2832" upper="6.2832" velocity="3.927"/>
		<dynamics friction="0"/>
	</joint>
	<link name="link6">
		<inertial>
			<mass value="1.16"/>
			<origin xyz="-0.000292 7e-06 -0.0539"/>
			<inertia ixx="0.0048282" ixy="4.1298e-06" ixz="6.9879e-06" iyy="0.0059519" iyz="4.252e-06" izz="0.0061263"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_blue/MF1013_6_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<mesh filename="package://robot_arm/meshes/m1013_collision/MF1013_6_0.dae" scale="0.001 0.001 0.001"/>
			</geometry>
		</collision>
	</link>

	<!-- ==================== Tool Flange Frame ==================== -->
	<joint name="tool0_joint" type="fixed">
		<parent link="link6"/>
		<child link="tool0"/>
		<origin xyz="0 0 0" rpy="0 0 0"/>
	</joint>
	<link name="tool0"/>

	<!-- ==================== Simple Box Gripper ==================== -->
	<!-- Robotiq Hand-E was replaced by a from-scratch minimal design:
	     - Palm: dark box plate attached to tool0 (where Hand-E base was).
	     - Right finger: thin grey prism, FIXED on the +X side of the palm.
	     - Left finger:  thin grey prism, prismatic joint along +X. Slides
	       between OPEN (-X end) and CLOSED (meets right pad at center).
	     Single moving joint = guaranteed to work; no mesh, no mimic, no
	     fancy physics. -->

	<joint name="robotiq_hande_base_joint" type="fixed">
		<parent link="tool0"/>
		<child link="hand_e_link"/>
		<origin xyz="0 0 0" rpy="0 0 0"/>
	</joint>

	<!-- Palm: thin plate, ~6cm wide (X), ~4cm deep (Y), 5cm tall (Z).
	     Spans Z = 0 .. 0.05 from tool0. -->
	<link name="hand_e_link">
		<inertial>
			<origin rpy="0 0 0" xyz="0 0 0.025"/>
			<mass value="0.3"/>
			<inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0.025"/>
			<geometry>
				<box size="0.060 0.040 0.050"/>
			</geometry>
			<material name="GripperPalm">
				<color rgba="0.15 0.15 0.15 1.0"/>
			</material>
		</visual>
		<collision>
			<origin rpy="0 0 0" xyz="0 0 0.025"/>
			<geometry>
				<box size="0.060 0.040 0.050"/>
			</geometry>
		</collision>
	</link>

	<!-- Right finger: FIXED on +X side. Pad spans X: +0.015 .. +0.025,
	     Z: 0.050 .. 0.130. -->
	<joint name="hande_right_finger_joint" type="fixed">
		<parent link="hand_e_link"/>
		<child link="hande_right_finger"/>
		<origin rpy="0 0 0" xyz="0.020 0 0.090"/>
	</joint>
	<link name="hande_right_finger">
		<inertial>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<mass value="0.02"/>
			<inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<box size="0.010 0.025 0.080"/>
			</geometry>
			<material name="GripperFinger">
				<color rgba="0.55 0.55 0.55 1.0"/>
			</material>
		</visual>
	</link>

	<!-- Left finger: PRISMATIC, single moving joint of the gripper.
	     Joint origin sits at the OPEN pose (-0.020 X). Axis +X.
	     - joint = 0     → link at (-0.020, 0, 0.090): pad spans X -0.025..-0.015 → OPEN, ~30mm gap
	     - joint = 0.030 → link at (+0.010, 0, 0.090): pad spans X +0.005..+0.015 → CLOSED, touching right pad inner face -->
	<joint name="hande_left_finger_joint" type="prismatic">
		<parent link="hand_e_link"/>
		<child link="hande_left_finger"/>
		<origin rpy="0 0 0" xyz="-0.020 0 0.090"/>
		<axis xyz="1 0 0"/>
		<limit effort="100" lower="0.0" upper="0.030" velocity="1.0"/>
		<dynamics damping="0.0" friction="0.0"/>
	</joint>
	<link name="hande_left_finger">
		<inertial>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<mass value="0.02"/>
			<inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
		</inertial>
		<visual>
			<origin rpy="0 0 0" xyz="0 0 0"/>
			<geometry>
				<box size="0.010 0.025 0.080"/>
			</geometry>
			<material name="GripperFinger">
				<color rgba="0.55 0.55 0.55 1.0"/>
			</material>
		</visual>
	</link>

	<!-- TCP frame (gripper tip center) -->
	<joint name="tcp_joint" type="fixed">
		<parent link="hand_e_link"/>
		<child link="tcp"/>
		<!-- 0.099 (finger origin) + ~0.05 (finger length) = ~0.14 from hand_e_link -->
		<origin xyz="0 0 0.14" rpy="0 0 0"/>
	</joint>
	<link name="tcp">
		<visual>
			<geometry>
				<sphere radius="0.005"/>
			</geometry>
			<material name="tcp_red">
				<color rgba="1 0 0 1"/>
			</material>
		</visual>
	</link>

	<!-- ==================== Wrist-Mounted RGB-D Camera ==================== -->
	<!-- Mounted on link6 (before gripper), offset to side to avoid occlusion -->
	<joint name="camera_joint" type="fixed">
		<parent link="link6"/>
		<child link="camera_link"/>
		<!-- Camera +X (Gazebo look direction) aligned with link6 +Z (approach direction) -->
		<!-- X=-0.08: far back from gripper, Z=-0.02: slight side offset -->
		<origin xyz="-0.14 0 -0.02" rpy="0 -1.5708 0"/>
	</joint>
	<link name="camera_link">
		<visual>
			<geometry>
				<box size="0.06 0.09 0.06"/>
			</geometry>
			<material name="camera_black">
				<color rgba="0.1 0.1 0.1 1"/>
			</material>
		</visual>
		<!-- Mounting arm connecting camera back to link6 -->
		<visual>
			<origin xyz="0.01 0 -0.07" rpy="0 0 0"/>
			<geometry>
				<cylinder radius="0.012" length="0.14"/>
			</geometry>
			<material name="camera_mount_grey">
				<color rgba="0.4 0.4 0.4 1"/>
			</material>
		</visual>
		<collision>
			<geometry>
				<box size="0.06 0.09 0.06"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.05"/>
			<inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
		</inertial>
	</link>

	<!-- ROS optical frame convention: Z forward, X right, Y down -->
	<joint name="camera_optical_joint" type="fixed">
		<parent link="camera_link"/>
		<child link="camera_optical_frame"/>
		<origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
	</joint>
	<link name="camera_optical_frame"/>

	<!-- Gazebo Sim RGB-D sensor -->
	<gazebo reference="camera_link">
		<sensor type="rgbd_camera" name="wrist_rgbd_camera">
			<always_on>true</always_on>
			<update_rate>30.0</update_rate>
			<topic>camera</topic>
			<ignition_frame_id>camera_optical_frame</ignition_frame_id>
			<camera name="wrist_camera">
				<horizontal_fov>1.57</horizontal_fov>
				<image>
					<width>640</width>
					<height>480</height>
					<format>R8G8B8</format>
				</image>
				<lens>
					<intrinsics>
						<fx>277</fx>
						<fy>277</fy>
						<cx>320</cx>
						<cy>240</cy>
						<s>0</s>
					</intrinsics>
				</lens>
				<clip>
					<near>0.05</near>
					<far>3.0</far>
				</clip>
				<depth_camera>
					<clip>
						<near>0.05</near>
						<far>3.0</far>
					</clip>
				</depth_camera>
				<noise>
					<type>gaussian</type>
					<mean>0.0</mean>
					<stddev>0.007</stddev>
				</noise>
			</camera>
		</sensor>
	</gazebo>

	<!-- Gripper finger physics: disable gravity on both fingers and the
	     palm so the prismatic left finger never gets dragged by any small
	     gravity component (axis is +X / horizontal in palm frame, but when
	     the arm tilts the world-frame gravity gains an X component which
	     would otherwise bias the joint). No friction tags — collision is
	     disabled on fingers anyway. -->
	<gazebo reference="hand_e_link">
		<gravity>false</gravity>
	</gazebo>
	<gazebo reference="hande_left_finger">
		<gravity>false</gravity>
	</gazebo>
	<gazebo reference="hande_right_finger">
		<gravity>false</gravity>
	</gazebo>

	<!-- ==================== ros2_control ==================== -->
	<ros2_control name="m1013_robocot_control" type="system">
		<hardware>
			<plugin>ign_ros2_control/IgnitionSystem</plugin>
		</hardware>
		<!-- Arm joints (6-DOF revolute) -->
		<joint name="joint1">
			<command_interface name="position">
				<param name="min">-6.2832</param>
				<param name="max">6.2832</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="joint2">
			<command_interface name="position">
				<param name="min">-6.2832</param>
				<param name="max">6.2832</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="joint3">
			<command_interface name="position">
				<param name="min">-2.7925</param>
				<param name="max">2.7925</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="joint4">
			<command_interface name="position">
				<param name="min">-6.2832</param>
				<param name="max">6.2832</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="joint5">
			<command_interface name="position">
				<param name="min">-6.2832</param>
				<param name="max">6.2832</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<joint name="joint6">
			<command_interface name="position">
				<param name="min">-6.2832</param>
				<param name="max">6.2832</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
		<!-- Gripper joint (left finger only — right finger is a fixed link). -->
		<joint name="hande_left_finger_joint">
			<command_interface name="position">
				<param name="min">0.0</param>
				<param name="max">0.030</param>
			</command_interface>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
	</ros2_control>

	<!-- ==================== Gazebo Sim ROS2 Control Plugin ==================== -->
	<gazebo>
		<plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
			<parameters>$(arg controllers_yaml)</parameters>
		</plugin>
	</gazebo>

</robot>
